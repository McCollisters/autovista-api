<html>

  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>Your McCollister's Auto Transport Quote</title>
  </head>

  <body
    style="font-size: 14px; margin: 0 auto; width: 600px; padding: 0; -webkit-text-size-adjust:100%; -ms-text-size-adjust:100%;"
  >
    <table
      class="table"
      cellpadding="0"
      cellspacing="0"
      style="empty-cells: hide; margin: 0 auto; padding: 15px; width: 600px"
    >
      {{#unless isShareRecipient}}
        <tr>
          <td valign="top" style="width: 600px; margin: 0 auto;">
            <p
              style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.4; margin-bottom: 15px;"
            >Hi
              {{firstName}},</p>
          </td>
        </tr>
      {{/unless}}

      <tr>
        <td valign="top" style="width: 600px; margin: 0 auto;">
          <p
            style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.4; margin: 0 0 15px;"
          >{{#if isShareRecipient}}{{sharerName}} requested an auto transport quote through the
            McCollister's app and wanted to share it with you.{{else}}Thank you for requesting an auto transport quote through the
            McCollister's app.{{/if}}</p>
          <p
            style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.4; margin: 0 0 15px;"
          >{{#if isShareRecipient}}This email includes a summary of vehicle and route details, along with pricing options based on different pickup windows.{{else}}Your quote is ready. This email includes a summary of your vehicle
            and route details, along with pricing options based on different
            pickup windows to help you choose the option that best fits your
            budget and schedule.{{/if}}</p>
          <p
            style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.4; margin: 0 0 15px;"
          >{{#if isShareRecipient}}This order can be booked by clicking the Book Now button below. You'll be asked to enter the confirmation code shown here to access the quote and complete the booking.{{else}}When you're ready to move forward, you can book your order using the
            Book Now button below. After clicking, you'll be asked to enter the
            confirmation code shown here to access your quote and complete your
            booking.{{/if}}</p>
        </td>
      </tr>

      <tr>
        <td
          valign="top"
          style="width: 600px; margin: 0 auto;"
        >
          <p
            style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 12px;"
          ><strong>Confirmation Code:</strong> {{code}}</p>
        </td>
      </tr>

      <tr>
        <td
          valign="top"
          style="width: 600px; margin: 0 auto; padding-bottom: 20px;"
        >
          <table cellpadding="0" cellspacing="0" role="presentation">
            <tr>
              <td style="border-radius: 15px; background-color: #000000;">
                <a
                  href="{{bookUrl}}"
                  style="display: inline-block; padding: 14px 28px; font-family: Helvetica, Arial, sans-serif; font-size: 14px; font-weight: 700; color: #ffffff; text-decoration: none; text-transform: uppercase; letter-spacing: 0.05em;"
                >BOOK NOW</a>
              </td>
            </tr>
          </table>
        </td>
      </tr>

      <tr>
        <td valign="top" style="width: 600px; margin: 0 auto;">
          <p
            style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.4; margin: 0 0 12px; font-size: 15px;"
          ><strong>Your Quote Summary:</strong></p>
          <p
            style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px;"
          ><strong>Quote #</strong>{{refIdDisplay}}</p>
          <p
            style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px;"
          ><strong>Pickup Location:</strong> {{pickupLocation}}</p>
          <p
            style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px;"
          ><strong>Delivery Location:</strong> {{deliveryLocation}}</p>
          <p
            style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 12px;"
          ><strong>Transport Type:</strong> {{transportType}}</p>
          <p
            style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 16px;"
          ><strong>Vehicle(s):</strong> {{vehiclesSummary}}</p>
        </td>
      </tr>

      <tr>
        <td valign="top" style="width: 600px; margin: 0 auto;">
          {{#if isWhiteGlove}}
          <p
            style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.4; margin: 0 0 10px;"
          ><strong>White Glove Pricing:</strong></p>
          {{else}}
          <p
            style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.4; margin: 0 0 10px;"
          ><strong>Pricing Options by Pickup Window:</strong></p>
          {{/if}}
        </td>
      </tr>

      {{#if isWhiteGlove}}
        <tr>
          <td
            style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.6; padding-bottom: 6px;"
          >{{whiteGlovePriceDisplay}}</td>
        </tr>
      {{else}}
        <tr>
          <td
            style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.6; padding-bottom: 4px;"
          >{{pickupLabelOne}} &mdash; {{priceOne}}</td>
        </tr>
        <tr>
          <td
            style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.6; padding-bottom: 4px;"
          >{{pickupLabelThree}} &mdash; {{priceThree}}</td>
        </tr>
        <tr>
          <td
            style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.6; padding-bottom: 4px;"
          >{{pickupLabelFive}} &mdash; {{priceFive}}</td>
        </tr>
        <tr>
          <td
            style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.6; padding-bottom: 4px;"
          >{{pickupLabelSeven}} &mdash; {{priceSeven}}</td>
        </tr>
      {{/if}}

      <tr>
        <td
          valign="top"
          style="width: 600px; margin: 0 auto; padding-top: 16px;"
        >
          <p
            style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 16px; font-style: italic;"
          >This quote is valid for 10 days from the date issued. Pricing and
            availability may change after this period.</p>
          <p
            style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 20px;"
          >If you have questions or need assistance before booking, our team is
            here to help.</p>
          <p
            style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px;"
          >McCollister's Auto Logistics</p>
          <img
            src="{{logo}}"
            alt=""
            style="width: 250px; margin-right: 20px; height: auto;"
          />
          <p
            style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin-top: 12px;"
          ><a href="tel:8888190594" style="color: #0069ca;">(888) 819-0594</a><br
            />autologistics@mccollisters.com</p>
        </td>
      </tr>
    </table>
  </body>

</html>