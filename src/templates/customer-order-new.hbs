<html>

<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>Order Confirmation</title>
</head>

<body style="font-size: 14px; margin: 0 auto; width: 600px; padding: 0; -webkit-text-size-adjust:100%; -ms-text-size-adjust:100%;">
    <table class="table" cellpadding="0" cellspacing="0" style="empty-cells: hide; margin: 0 auto; padding: 15px; width: 600px">
        <tr>
            <td valign="top" style="width: 600px; margin: 0 auto;">
                {{#unless isShareRecipient}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.4; margin-bottom: 15px; ">Hi {{recipientFirstName}},</p>
                {{/unless}}
                {{#if isShareRecipient}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.4; margin-bottom: 15px; ">{{sharerName}} booked an auto transport order through McCollister's and wanted to share the confirmation with you.</p>
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.4; margin-bottom: 20px; ">This email includes a summary of the transport details, including the selected pickup window and vehicle information. Please review the information below and keep this email for your records.</p>
                {{else}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.4; margin-bottom: 15px; ">Your auto transport order has been successfully booked.</p>
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.4; margin-bottom: 15px; ">This email confirms your order and includes a summary of your transport details, including your selected pickup window and vehicle information. Please review the information below and keep this email for your records.</p>
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.4; margin-bottom: 20px; ">Our team will be in touch as your pickup window approaches.</p>
                {{/if}}

                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.4; margin: 0 0 12px 0; font-size: 16px; font-weight: bold;">Order Summary</p>
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px 0;"><strong>Order Number:</strong> {{refId}}</p>
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px 0;"><strong>Transport Type:</strong> {{transportTypeDisplay}}</p>
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px 0;"><strong>Vehicle(s):</strong> {{vehiclesPlain}}</p>
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px 0;"><strong>{{pickupDetailLabel}}*:</strong> {{pickupDetailDisplay}}</p>
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 24px 0;"><strong>{{deliveryDetailLabel}}*:</strong> {{deliveryDetailDisplay}}</p>

                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.4; margin: 0 0 12px 0; font-size: 16px; font-weight: bold;">Pickup Details</p>
                {{#if pickupDetails.businessName}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px 0;"><strong>Business Name:</strong> {{pickupDetails.businessName}}</p>
                {{/if}}
                {{#if pickupDetails.contactName}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px 0;"><strong>Contact Name:</strong> {{pickupDetails.contactName}}</p>
                {{/if}}
                {{#if pickupDetails.email}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px 0;"><strong>Email:</strong> {{pickupDetails.email}}</p>
                {{/if}}
                {{#if pickupDetails.phone}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px 0;"><strong>Phone:</strong> {{pickupDetails.phone}}</p>
                {{/if}}
                {{#if pickupDetails.mobilePhone}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px 0;"><strong>Mobile Phone:</strong> {{pickupDetails.mobilePhone}}</p>
                {{/if}}
                {{#if pickupDetails.alternativePhone}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px 0;"><strong>Alternative Phone:</strong> {{pickupDetails.alternativePhone}}</p>
                {{/if}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px 0;"><strong>Pickup Address:</strong><br />{{pickupDetails.addressLine1Display}}{{#if pickupDetails.addressLine2Display}}<br />{{pickupDetails.addressLine2Display}}{{/if}}</p>
                {{#if pickupDetails.notes}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 0 0;"><strong>Pickup Notes:</strong> {{pickupDetails.notes}}</p>
                {{/if}}

                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.4; margin: 0 0 12px 0; font-size: 16px; font-weight: bold;">Delivery Details</p>
                {{#if deliveryDetails.businessName}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px 0;"><strong>Business Name:</strong> {{deliveryDetails.businessName}}</p>
                {{/if}}
                {{#if deliveryDetails.contactName}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px 0;"><strong>Contact Name:</strong> {{deliveryDetails.contactName}}</p>
                {{/if}}
                {{#if deliveryDetails.email}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px 0;"><strong>Email:</strong> {{deliveryDetails.email}}</p>
                {{/if}}
                {{#if deliveryDetails.phone}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px 0;"><strong>Phone:</strong> {{deliveryDetails.phone}}</p>
                {{/if}}
                {{#if deliveryDetails.mobilePhone}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px 0;"><strong>Mobile Phone:</strong> {{deliveryDetails.mobilePhone}}</p>
                {{/if}}
                {{#if deliveryDetails.alternativePhone}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px 0;"><strong>Alternative Phone:</strong> {{deliveryDetails.alternativePhone}}</p>
                {{/if}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px 0;"><strong>Delivery Address:</strong><br />{{deliveryDetails.addressLine1Display}}{{#if deliveryDetails.addressLine2Display}}<br />{{deliveryDetails.addressLine2Display}}{{/if}}</p>
                {{#if deliveryDetails.notes}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 0 0;"><strong>Delivery Notes:</strong> {{deliveryDetails.notes}}</p>
                {{/if}}
            </td>
        </tr>

        {{#if showPaymentSection}}
        <tr>
            <td valign="top" style="width: 600px; margin: 0 auto; padding-top: 24px;">
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.4; margin: 0 0 12px 0; font-size: 16px; font-weight: bold;">Complete Your Booking — Payment Required</p>
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 12px 0;">To officially schedule your vehicle for pickup, payment must be submitted in full.</p>
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 28px 0;">Please use the secure link below to complete payment.</p>
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 32px 0;">
                    <a href="{{paymentUrl}}" style="display: inline-block; padding: 12px 22px; background-color: #000000; color: #ffffff !important; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 14px;">Make a Payment</a>
                </p>
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 0 0;">Your order will be scheduled once payment is received.**</p>
            </td>
        </tr>
        {{/if}}

        <tr>
            <td valign="top" style="width: 600px; margin: 0 auto; padding-top: 24px;">
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.4; margin: 0 0 12px 0; font-size: 16px; font-weight: bold;">What You Can Do Next</p>
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px 0;"><strong>Review Terms &amp; Conditions:</strong></p>
                {{#if isShareRecipient}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 12px 0;">View the Terms &amp; Conditions the customer agreed to at the time of booking:<br />
                    <a href="{{termsUrl}}">View Terms &amp; Conditions</a></p>
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px 0;"><strong>Customer portal:</strong></p>
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 12px 0;">The booking customer can log in to the customer portal to follow the progress of this transport and view order details. The link below opens the portal with the account email on file:<br />
                    <a href="{{orderStatusUrl}}">Go to Customer Portal</a></p>
                {{else}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 12px 0;">View the Terms &amp; Conditions you agreed to at the time of booking:<br />
                    <a href="{{termsUrl}}">View Terms &amp; Conditions</a></p>
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px 0;"><strong>Access Your Customer Portal:</strong></p>
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 12px 0;">Log in to your customer portal to follow the progress of your transport and view your order details:<br />
                    <a href="{{orderStatusUrl}}">Go to Customer Portal</a></p>
                {{/if}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 8px 0;"><strong>Learn more:</strong></p>
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 12px 0;"><a href="{{faqUrl}}">Explore our FAQs for answers</a></p>
                {{#if isShareRecipient}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 0 0;">If you or the booking customer have questions or need assistance, our team is here to help.</p>
                {{else}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 0 0;">If you have questions or need assistance at any point, our team is here to help.</p>
                {{/if}}
            </td>
        </tr>

        <tr>
            <td valign="top" style="width: 600px; margin: 0 auto; padding-top: 24px;">
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.4; margin: 0 0 12px 0; font-size: 16px; font-weight: bold;">Important Notes</p>
                {{#if isShareRecipient}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 12px 0; font-size: 13px;">*Please note that the booking customer (or their delegate) must be available Monday–Friday, 9:00 AM–6:00 PM during the entire pickup and delivery windows listed above. If they are unable to release or accept the vehicle(s) during the full window, they may assign a delegate to act on their behalf. The delegate's name and contact information should be provided as soon as possible.</p>
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 12px 0; font-size: 13px;">If no one is available during the required window, additional terminal storage or redelivery fees may apply.</p>
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 0 0; font-size: 13px;">The booking customer or their assigned delegate will be notified one day in advance of the actual pickup and delivery date and provided with an estimated arrival window. Arrival times are subject to change due to factors such as traffic, weather, mechanical issues, or prior scheduling delays. Drivers may arrive anytime between 9:00 AM and 6:00 PM.</p>
                {{else}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 12px 0; font-size: 13px;">*Please note that you must be available Monday–Friday, 9:00 AM–6:00 PM during the entire pickup and delivery windows listed above. If you are unable to release or accept your vehicle(s) during the full window, you may assign a delegate to act on your behalf. Please provide your delegate's name and contact information as soon as possible.</p>
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 12px 0; font-size: 13px;">If no one is available during the required window, additional terminal storage or redelivery fees may apply.</p>
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 0 0 0 0; font-size: 13px;">You or your assigned delegate will be notified one day in advance of the actual pickup and delivery date and provided with an estimated arrival window. Arrival times are subject to change due to factors such as traffic, weather, mechanical issues, or prior scheduling delays. Drivers may arrive anytime between 9:00 AM and 6:00 PM.</p>
                {{/if}}
                {{#if showPaymentSection}}
                <p style="box-sizing: border-box; font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.5; margin: 12px 0 0 0; font-size: 13px;">**Your order will not be officially scheduled for pickup until payment is received in full via credit card. We do not allow customers to pay drivers directly. Payment must be received at least three (3) business days prior to your scheduled pickup date.</p>
                {{/if}}
            </td>
        </tr>

        <tr>
            <td valign="top" style="width: 600px; margin: 0 auto; padding-top: 24px; padding-bottom: 15px;">
               <p style="font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.4; margin: 0 0 12px 0;">McCollister's Auto Transport</p>
                <img
                    src="{{logo}}"
                    alt="McCollister's Auto Transport"
                    width="220"
                    style="display: block; width: 220px; max-width: 220px; height: auto; border: 0; outline: none; text-decoration: none; -ms-interpolation-mode: bicubic; margin: 0 0 12px 0;"
                />
               <p style="font-family: Helvetica, Arial, sans-serif; letter-spacing: 0.5px; line-height: 1.4; margin: 0;"><a href="tel:8888190594">(888) 819-0594</a><br />autotransport@mccollisters.com</p>
            </td>
        </tr>

    </table>
</body>


</html>
