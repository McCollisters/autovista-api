# Auto Scaling: ensure we never scale to 0 and reduce aggressive scale-down.
#
# The default "AWSEBCloudwatchAlarmLow" fires when NetworkOut < 2MB in 5 minutes,
# which triggers scale-in. If the environment scales down too far or to 0,
# some clients get no healthy target and see connection failures.
#
# - MinSize 1: always keep at least one instance so the API is reachable.
# - LowerThreshold 500000 (500KB): only scale down when traffic is very low,
#   so we don't scale in during brief quiet periods that still have some clients.
#
# For high availability (survive one instance/AZ failure), set MinSize to 2 in
# the AWS Console (Configuration → Capacity → Min instances).

option_settings:
  aws:autoscaling:asg:
    MinSize: "1"
    MaxSize: "4"
  aws:autoscaling:trigger:
    LowerThreshold: "500000"
    MeasureName: "NetworkOut"
    Period: "5"
    BreachDuration: "5"
    Statistic: "Average"
    Unit: "Bytes"
